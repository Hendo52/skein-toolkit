# Docker Compose environment for the litellm service.
# Copy to docker/.env (gitignored) and fill in real values -- this file is a
# template only and must not contain real credentials.

# Cloudflare Workers AI via the mcp-server container's /cfproxy proxy.
# Use the service name "mcp-server" as the host when running under Compose.
CF_API_BASE=http://mcp-server:3100/cfproxy/YOUR_ACCOUNT_ID/v1
CF_API_KEY=cfut_YOUR_KEY_HERE

# Anthropic direct API
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI direct API (optional)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Groq (optional)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# DeepSeek (optional)
DEEPSEEK_API_KEY=sk-YOUR_KEY_HERE

# LiteLLM admin master key (any strong random string)
LITELLM_MASTER_KEY=sk-local-change-this-to-something-secret
