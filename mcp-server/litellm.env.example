# LiteLLM environment variables — copy to mcp-server/litellm.env and fill in values.
# litellm.env is gitignored (contains credentials).

# Cloudflare Workers AI via local-mcp.py proxy
CF_API_BASE=http://127.0.0.1:3100/cfproxy/YOUR_ACCOUNT_ID/v1
CF_API_KEY=cfut_YOUR_KEY_HERE

# Anthropic direct API
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI direct API (optional)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Groq (GroqCloud) -- console.groq.com/keys
# Used for groq/gpt-oss-120b, groq/kimi-k2 (alternative-host test, 2026-06-11)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# DeepSeek -- platform.deepseek.com/api_keys
# Used for deepseek/v4-flash (alternative-host test, 2026-06-11)
DEEPSEEK_API_KEY=sk-YOUR_KEY_HERE

# LiteLLM admin master key (any strong random string)
LITELLM_MASTER_KEY=sk-local-change-this-to-something-secret

# Spend tracking: per-request costs logged to ~/.litellm/costs.jsonl
# Full persistent DB requires PostgreSQL (set DATABASE_URL below if used)
